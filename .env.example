# Discord Bot Token
# 从 Discord Developer Portal 获取: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# LiteLLM API Key
# 用于调用 AI 模型
LITELLM_API_KEY=your_litellm_api_key_here

# X (Twitter) API Credentials
# 从 X Developer Portal 获取: https://developer.x.com/en/portal/dashboard
# 注意：App 权限需要设置为 Read and Write
X_API_KEY=your_api_key_here
X_API_SECRET=your_api_secret_here
X_ACCESS_TOKEN=your_access_token_here
X_ACCESS_SECRET=your_access_token_secret_here

# Google Analytics
# GA4 Property ID (在 GA 管理界面查看)
GA_PROPERTY_ID=your_ga_property_id_here
# Service Account JSON 凭证的 base64 编码
# 获取方法: base64 -i your-service-account.json
GA_CREDENTIALS_BASE64=your_base64_encoded_credentials_here
