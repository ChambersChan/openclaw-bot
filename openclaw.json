{
  "gateway": {
    "mode": "local"
  },
  "channels": {
    "discord": {
      "token": "${DISCORD_BOT_TOKEN}",
      "enabled": true,
      "groupPolicy": "open",
      "allowFrom": ["*"],
      "streaming": "partial",
      "ackReaction": "👀",
      "replyToMode": "first",
      "execApprovals": {
        "enabled": false
      }
    }
  },
  "messages": {
    "groupChat": {
      "mentionPatterns": ["@zoe-claw", "zoe-claw"]
    }
  },
  "commands": {
    "allowFrom": {
      "discord": ["*"]
    }
  },
    "models": {
    "providers": {
      "litellm": {
        "baseUrl": "https://llm.bika.ltd",
        "apiKey": "${LITELLM_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "gemini-3.1-pro",
            "name": "Gemini 3.1 Pro",
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "gemini-3-flash",
            "name": "Gemini 3 Flash",
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": { "primary": "litellm/gemini-3.1-pro" },
      "skipBootstrap": true
    }
  },
  "tools": {
    "allow": ["*"],
    "elevated": {
      "enabled": false,
      "allowFrom": {
        "discord": ["*"]
      }
    }
  },
  "cron": {
    "enabled": true,
    "store": "~/.openclaw/cron/jobs.json",
    "maxConcurrentRuns": 3,
    "sessionRetention": "24h",
    "runLog": {
      "maxBytes": "2mb",
      "keepLines": 500
    }
  }
}